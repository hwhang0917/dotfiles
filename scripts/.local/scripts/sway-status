#!/bin/sh

if [ ! -f /proc/stat ]; then
    echo "[ERROR] /proc/stat not found. Linux required." >&2
    exit 1
fi

# Date/time with seconds
datetime=$(date +'%Y/%m/%d (%a) %H:%M:%S')

# Battery info (CMB0 is your battery)
bat_path=/sys/class/power_supply/CMB0
if [ ! -d "$bat_path" ]; then
    echo "[ERROR] Battery not found at $bat_path." >&2
    exit 1
fi
battery_percent=$(cat "$bat_path/capacity")
battery_status=$(cat "$bat_path/status")

if [ "$battery_status" = "Charging" ]; then
    if   [ "$battery_percent" -ge 75 ]; then battery_icon="σΑ²Ö"
    elif [ "$battery_percent" -ge 50 ]; then battery_icon="σΑ²΄"
    elif [ "$battery_percent" -ge 25 ]; then battery_icon="σΑ²΅"
    else                                     battery_icon="σΑΔü"
    fi
else
    if   [ "$battery_percent" -ge 75 ]; then battery_icon="σΑ¹Ι"
    elif [ "$battery_percent" -ge 50 ]; then battery_icon="σΑ²Ä"
    elif [ "$battery_percent" -ge 25 ]; then battery_icon="σΑ¹Μ"
    else                                     battery_icon="σΑ²é"
    fi
fi

# CPU usage (instant read βÄî no sleep)
read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
cpu_total=$((user + nice + system + idle + iowait + irq + softirq + steal))
cpu_idle=$((idle + iowait))
state_file="/tmp/sway_cpu_last"
if [ -f "$state_file" ]; then
    read -r last_total last_idle < "$state_file"
    cpu_diff=$((cpu_total - last_total))
    idle_diff=$((cpu_idle - last_idle))
    if [ "$cpu_diff" -gt 0 ]; then
        cpu_percent=$(( (100 * (cpu_diff - idle_diff)) / cpu_diff ))
    else
        cpu_percent=0
    fi
else
    cpu_percent=0
fi
echo "$cpu_total $cpu_idle" > "$state_file"

# Memory usage
mem_total=$(awk '/^MemTotal:/ {print $2}' /proc/meminfo)
mem_avail=$(awk '/^MemAvailable:/ {print $2}' /proc/meminfo)
memory_percent=$(( (100 * (mem_total - mem_avail)) / mem_total ))

# Wi-Fi status
iface="wlp1s0"
if [ -d "/sys/class/net/$iface" ]; then
    operstate=$(cat "/sys/class/net/$iface/operstate")
    if [ "$operstate" = "up" ]; then
        ssid=$(iw dev "$iface" link | awk -F': ' '/SSID/ {print $2}')
        if [ -n "$ssid" ]; then
            wifi_status="σΑ•© $ssid"
        else
            wifi_status="σΑ•Σ disconnected"
        fi
    else
        wifi_status="σΑ•≠ disabled"
    fi
else
    wifi_status="σΑ•≠ disabled"
fi

# Output with fixed-width formatting (no jitter)
printf "%s | %s  σΑç¦ %3d%%  σΑΜ† %3d%%  %s %3d%%\n" \
    "$datetime" "$wifi_status" "$memory_percent" "$cpu_percent" "$battery_icon" "$battery_percent"
