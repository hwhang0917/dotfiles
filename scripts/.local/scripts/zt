#!/usr/bin/zsh

# Zoxide + Tmux: open a zoxide result in a new tmux window

if ! command -v zoxide >/dev/null 2>&1; then
    echo "[ERROR] zoxide is not installed." >&2
    exit 1
fi
if [[ -z "$TMUX" ]]; then
    echo "[ERROR] Not inside a tmux session." >&2
    exit 1
fi

result=$(zoxide query --interactive "$@") || exit 1
window_name=$(basename "$result")
tmux new-window -n "$window_name" -c "$result"
