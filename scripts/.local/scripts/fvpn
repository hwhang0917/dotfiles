#!/bin/sh

# WireGuard toggle helper with fzf

log() {
    level="$1"
    shift
    printf "[%s] %s\n" "$level" "$*"
}

for dep in fzf wg wg-quick; do
    if ! command -v "$dep" > /dev/null 2>&1; then
        log "ERROR" "$dep is not installed."
        exit 1
    fi
done

conf_dir="/etc/wireguard"
if [ ! -d "$conf_dir" ]; then
    log "ERROR" "No WireGuard config directory found at $conf_dir"
    exit 1
fi

search_term="${1:-}"
active_ifaces=$(sudo wg show interfaces 2>/dev/null)

# if any VPN is active, offer to bring it down first
if [ -n "$active_ifaces" ]; then
    filtered_active=""
    for iface in $active_ifaces; do
        [ "$iface" = "wg0" ] && continue
        if [ -n "$filtered_active" ]; then
            filtered_active="$filtered_active $iface"
        else
            filtered_active="$iface"
        fi
    done

    if [ -n "$filtered_active" ]; then
        active_list=$(echo "$filtered_active" | tr ' ' ',' | sed 's/,/, /g')
        printf "%s is currently up. Bring down? [Y/n] " "$active_list"
        read -r reply

        if [ "$reply" != "n" ] && [ "$reply" != "N" ]; then
            for iface in $filtered_active; do
                log "INFO" "Bringing down $iface..."
                sudo wg-quick down "$iface"
            done
        fi
        exit 0
    fi
fi

# pick an interface
selected=$(sudo find "$conf_dir" -maxdepth 1 -name "*.conf" 2>/dev/null | \
    sed 's|.*/||; s/\.conf$//' | \
    grep -v '^wg0$' | \
    while read -r iface; do
        if echo "$active_ifaces" | grep -qw "$iface"; then
            echo "$iface [UP]"
        else
            echo "$iface [DOWN]"
        fi
    done | \
    fzf \
    --height=40% \
    --layout=reverse \
    --border \
    --prompt="WireGuard > " \
    --query="$search_term")

if [ -n "$selected" ]; then
    iface=$(echo "$selected" | awk '{print $1}')
    state=$(echo "$selected" | awk '{print $2}')

    if [ "$state" = "[UP]" ]; then
        log "INFO" "Bringing down $iface..."
        sudo wg-quick down "$iface"
    else
        log "INFO" "Bringing up $iface..."
        sudo wg-quick up "$iface"
    fi
fi
