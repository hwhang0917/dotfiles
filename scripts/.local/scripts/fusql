#!/usr/bin/zsh

# USQL connection helper with fzf

if ! command -v fzf > /dev/null 2>&1; then
    echo "[ERROR] fzf is not installed." >&2
    exit 1
fi
if ! command -v usql > /dev/null 2>&1; then
    echo "[ERROR] usql is not installed." >&2
    exit 1
fi

config_file="$HOME/.config/usql/config.yaml"
if [[ ! -f $config_file ]]; then
    echo "[ERROR] No usql config file found at $config_file" >&2
    exit 1
fi

search_term="$1"

db=$(grep -E '^\s+[a-z_][a-z0-9_]*:\s' "$config_file" | \
    sed 's/^\s*//;s/:\s.*//' | \
    fzf \
    --height=40% \
    --layout=reverse \
    --border \
    --prompt="USQL > " \
    --query="$search_term")

if [[ -n $db ]]; then
    echo "[INFO] Connecting to $db..." >&2
    usql "$db"
fi
