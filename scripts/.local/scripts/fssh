#!/bin/sh

# SSH connection helper with fzf

if ! command -v fzf > /dev/null 2>&1; then
    echo "[ERROR] fzf is not installed." >&2
    exit 1
fi
if [ ! -f "$HOME/.ssh/config" ]; then
    echo "[ERROR] No SSH config file found at ~/.ssh/config" >&2
    exit 1
fi

search_term=""
[ $# -gt 0 ] && search_term="$1"

host=$(grep "^Host " ~/.ssh/config | grep -v "\*" | cut -d" " -f2- | fzf \
    --height=40% \
    --layout=reverse \
    --border \
    --prompt="SSH > " \
    --query="$search_term" \
    --preview="grep -A 2 'Host {}' ~/.ssh/config")

if [ -n "$host" ]; then
    echo "[INFO] Connecting to $host..." >&2
    ssh "$host"
fi
