#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SHA256_FILE="$SCRIPT_DIR/scripts.sha256"

if [[ ! -f "$SHA256_FILE" ]]; then
    echo "Missing checksum file: $SHA256_FILE" >&2
    exit 1
fi

failed=0
checked=0

while IFS=' ' read -r expected_hash filename; do
    [[ -z "$filename" || -z "$expected_hash" ]] && continue
    filepath="$SCRIPT_DIR/$filename"

    if [[ ! -f "$filepath" ]]; then
        echo "MISSING: $filename"
        ((failed++))
        ((checked++))
        continue
    fi

    actual_hash=$(sha256sum "$filepath" | cut -d' ' -f1)
    if [[ "$actual_hash" != "$expected_hash" ]]; then
        echo "MISMATCH: $filename"
        ((failed++))
    else
        echo "OK: $filename"
    fi
    ((checked++))
done < "$SHA256_FILE"

echo ""
echo "$checked checked, $failed failed"
[[ "$failed" -eq 0 ]]
