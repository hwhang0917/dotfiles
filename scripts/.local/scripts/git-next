#!/usr/bin/env bash

set -euo pipefail

base=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') || base="main"
next=$(git log --reverse --ancestry-path HEAD.."$base" --oneline | head -1 | cut -d' ' -f1)

if [[ -z "$next" ]]; then
    echo "Already at latest commit"
    exit 0
fi

git checkout "$next"
