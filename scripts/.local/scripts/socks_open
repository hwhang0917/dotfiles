#!/usr/bin/env bash
# socks_open — start a SOCKS5 proxy via SSH dynamic forwarding
#
# Usage: socks_open [ssh-host] [port]
#   ssh-host  SSH host alias from ~/.ssh/config (default: RFTunnel)
#   port      Local port to listen on (default: 1080)

set -euo pipefail

HOST="${1:-RFTunnel}"
PORT="${2:-1080}"

# ANSI colors
RED=$'\e[31m'
GREEN=$'\e[32m'
YELLOW=$'\e[33m'
BLUE=$'\e[34m'
BOLD=$'\e[1m'
RESET=$'\e[0m'

die() {
    echo "${RED}✗${RESET} $*" >&2
    exit 1
}

info() {
    echo "${BLUE}→${RESET} $*"
}

ok() {
    echo "${GREEN}✓${RESET} $*"
}

# Check if port is already in use
if ss -tlnH "sport = :${PORT}" 2>/dev/null | grep -q .; then
    existing_pid=$(ss -tlnpH "sport = :${PORT}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)
    if [[ -n "${existing_pid}" ]]; then
        cmd=$(ps -p "${existing_pid}" -o comm= 2>/dev/null || echo "unknown")
        die "Port ${PORT} already in use by pid ${existing_pid} (${cmd}). Run socks_kill first."
    else
        die "Port ${PORT} already in use."
    fi
fi

# Verify ssh host alias resolves (cheap sanity check)
if ! ssh -G "${HOST}" >/dev/null 2>&1; then
    die "SSH host alias '${HOST}' not found in ~/.ssh/config"
fi

info "Starting SOCKS5 proxy on ${BOLD}127.0.0.1:${PORT}${RESET} via ${BOLD}${HOST}${RESET}..."

# -f: background after auth
# -N: no remote command (just the tunnel)
# -D: dynamic (SOCKS) port forwarding
# ExitOnForwardFailure: don't silently succeed if the forward can't bind
ssh -fN -D "${PORT}" \
    -o ExitOnForwardFailure=yes \
    -o ServerAliveInterval=30 \
    -o ServerAliveCountMax=3 \
    "${HOST}"

# Give it a moment to establish
sleep 0.5

# Verify it actually came up
if ! ss -tlnH "sport = :${PORT}" 2>/dev/null | grep -q .; then
    die "SSH backgrounded but nothing is listening on :${PORT}"
fi

pid=$(ss -tlnpH "sport = :${PORT}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)

ok "SOCKS5 proxy alive on :${PORT} (pid ${pid:-?})"
echo
echo "  ${YELLOW}Test:${RESET}   curl --socks5-hostname localhost:${PORT} https://ifconfig.me"
echo "  ${YELLOW}Kill:${RESET}   socks_kill"
echo "  ${YELLOW}Firefox:${RESET} SOCKS5  127.0.0.1  ${PORT}  (check 'Proxy DNS when using SOCKS v5')"
